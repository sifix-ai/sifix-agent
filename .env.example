# RPC Configuration
RPC_URL=https://evmrpc-testnet.0g.ai

# AI Provider (choose one)
# OpenAI
OPENAI_API_KEY=sk-...

# Groq (fast & free)
# GROQ_API_KEY=gsk_...

# OpenRouter (multi-model)
# OPENROUTER_API_KEY=sk-or-...

# 0G Storage Configuration
ZEROG_INDEXER_URL=https://indexer-storage-testnet-standard.0g.ai
ZEROG_PRIVATE_KEY=0x...

# Mock Mode (for development/testing when testnet is unstable)
# Set to 'true' to generate deterministic hashes without actual uploads
# Set to 'false' or remove to use real 0G Storage
ZEROG_MOCK_MODE=false
